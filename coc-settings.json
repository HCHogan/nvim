    //"prisma",
    //"dart",
    //"terraform"
    //],
    //"prettier.printWidth": 100,
    //"prettier.disableLanguages": [],
    //"prettier.formatterPriority": 4,
    //"prettier.useTabs": true,
    //"prettier.trailingComma": "all",
    "explorer.width": 32,
    "explorer.quitOnOpen": true,
    "explorer.sources": [
        {
            "name": "buffer",
            "expand": false
        },
        {
            "name": "file",
            "expand": true
        }
    ],
    "explorer.file.column.indent.indentLine": true,
    "explorer.file.showHiddenFiles": true,
    "explorer.icon.enableNerdfont": true,
    "explorer.file.column.git.showIgnored": true,
    "explorer.keyMappingMode": "none",
    "explorer.buffer.showHiddenBuffers": false,
    "explorer.keyMappings.global": {
        "k": "nodePrev",
        "j": "nodeNext",
        "i": "toggleSelection",
        "<tab>": "actionMenu",
        "gl": "expandRecursive",
        "gh": "collapseRecursive",
        "l": [
            "wait",
            "expandable?",
            "expand",
            "open"
        ],
        "<cr>": [
            "wait",
            "expandable?",
            "cd",
            "open"
        ],
        "I": "open:vsplit",
        "o": [
            "wait",
            "expanded?",
            "collapse",
            "expand"
        ],
        "O": "open:tab",
        "n": "collapse",
        "h": "gotoParent",
        "yp": "copyFilepath",
        "yn": "copyFilename",
        "yy": "copyFile",
        "dd": "cutFile",
        "pp": "pasteFile",
        "dD": "deleteForever",
        "a": "addFile",
        "M": "addDirectory",
        "cw": "rename",
        ".": "toggleHidden",
        "zh": "toggleHidden",
        "R": "refresh",
        "?": "help",
        "q": "quit",
        "X": "systemExecute",
        "gd": "listDrive",
        "f": "search",
        "F": "searchRecursive",
        "B": "gotoSource:file",
        "b": "gotoSource:buffer",
        "[[": "sourcePrev",
        "]]": "sourceNext",
        "[d": "diagnosticPrev",
        "]d": "diagnosticNext",
        "[c": "gitPrev",
        "]c": "gitNext",
        "<<": "gitStage",
        ">>": "gitUnstage"
    },
	"rust-analyzer.enable": true,
	"rust-analyzer.server.path": "/usr/bin/rust-analyzer",
	"suggest.noselect": false,
	"translator.window.enableBorder": true,
	"translator.engines": [
		"youdao",
	],
	"sourcekit.commandPath": "/usr/bin/sourcekit-lsp"
	
}
